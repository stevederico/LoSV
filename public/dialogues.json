    "loft_npc": {
      "id": "loft_npc",
      "name": "Casey the Creative",
      "color": "#E74C3C",
      "location": "loft",
      "position": { "x": -3, "y": 0.1, "z": 0 },
      "spritePath": "/assets/textures/npc/casey-creative.png",
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Hey there! Welcome to the loft where culture meets code.",
            "This is Level 4: Team Building.",
            "Goal: Assemble and retain your dream team.",
            "A startup is only as strong as the people behind it!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Start Level 4: Team Building",
              "action": "start_simulator"
