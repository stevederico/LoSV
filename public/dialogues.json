        "fundraising_help": {
          "id": "fundraising_help",
          "trigger": "interaction",
          "lines": [
            "Fundraising is about telling a compelling story backed by data.",
            "Know your metrics cold: MRR, DAU, growth rate, unit economics.",
            "VCs invest in teams first, markets second, products third.",
            "Have a clear use of funds - what milestones will this money unlock?",
            "Don't give away too much equity too early. 15-20% for seed is typical.",
            "The best fundraise is when you don't desperately need the money!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Let's pitch some VCs!",
