    "accelerator_npc": {
      "id": "accelerator_npc",
      "name": "Jordan the Connector",
      "color": "#34495E",
      "location": "accelerator",
      "position": { "x": 0, "y": 0.1, "z": -2 },
      "spritePath": "/assets/textures/npc/jordan-connector.png",
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Welcome to the accelerator! I'm Jordan, your program director.",
            "This is Level 3: Fundraising.",
            "Goal: Raise your seed round by convincing investors.",
            "It's time to turn traction into capital!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Start Level 3: Fundraising",
              "action": "start_simulator"
