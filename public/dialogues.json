  "characters": {
    "house_npc": {
      "id": "house_npc",
      "name": "Sam the Visionary",
      "color": "#8B4513",
      "location": "house",
      "position": { "x": -5, "y": 0.1, "z": -3 },
      "spritePath": "/assets/textures/npc/sam-visionary.png",
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Welcome to your entrepreneurial journey!",
            "This is Level 1: Product Ideation at Your Home.",
            "Goal: Validate problem-solution fit in 3 rounds.",
            "Ready to brainstorm your next big idea?"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Start Level 1: Product Ideation",
              "action": "start_simulator"
            },
            {
              "text": "Tell me more about product ideation",
              "action": "dialogue",
              "nextDialogue": "ideation_help"
            },
            {
              "text": "I'll come back later",
              "action": "close"
            }
          ]
        },
        "ideation_help": {
          "id": "ideation_help",
          "trigger": "interaction",
          "lines": [
            "Remember: Focus on real problems people face.",
            "Consider your target users carefully - who exactly needs this solution?",
            "Think about your value proposition - what unique benefit do you provide?",
            "Assess technical feasibility - can you actually build this?",
            "User feedback is crucial - listen to what potential customers say.",
            "Don't fall in love with your first idea - be ready to pivot!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "I'm ready to start!",
              "action": "start_simulator"
            },
            {
              "text": "Back to main menu",
              "action": "dialogue",
              "nextDialogue": "greeting"
            }
          ]
        }
      }
    },
