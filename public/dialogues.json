    "venture_npc": {
      "id": "venture_npc",
      "name": "VC Partner",
      "color": "#0088ff",
      "location": "venture",
      "position": { "x": -1, "y": 0.75, "z": -3 },
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Welcome to our venture capital firm!",
            "We invest in the future.",
            "Got a great startup idea?"
          ],
          "repeatable": true
        },
        "pitch_request": {
          "id": "pitch_request",
          "trigger": "interaction",
          "lines": [
            "Tell me about your startup.",
            "What's your business model?",
            "How much funding do you need?"
          ],
          "repeatable": false,
          "unlocks": ["funding_discussion"]
        },
        "funding_discussion": {
          "id": "funding_discussion",
          "trigger": "interaction",
          "lines": [
            "We typically invest $1M to $10M.",
            "We look for strong teams and scalable ideas.",
            "Come back when you have traction!"
          ],
          "repeatable": true,
          "requirements": ["pitch_request"]
        }
      }
    },
    "data_center_npc": {
      "id": "data_center_npc",
      "name": "Data Engineer",
      "color": "#00ffff",
      "location": "data-center",
      "position": { "x": -1, "y": 0.75, "z": -3 },
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Welcome to our data center!",
            "We process petabytes of data.",
            "The servers never sleep!"
          ],
          "repeatable": true
        },
        "tech_talk": {
          "id": "tech_talk",
          "trigger": "interaction",
          "lines": [
            "Our infrastructure handles millions of requests.",
            "We use cutting-edge cloud technology.",
            "Data is the new oil, they say!"
          ],
          "repeatable": true
        }
      }
    },
    "conference_npc": {
      "id": "conference_npc",
      "name": "Morgan the Marketer",
      "color": "#16A085",
      "location": "conference",
      "position": { "x": 0, "y": 0.1, "z": 2 },
      "spritePath": "/assets/textures/npc/morgan-marketer.png",
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Welcome to the big leagues! I'm Morgan, your growth strategist.",
            "This is Level 5: Go-to-Market Strategy.",
            "Goal: Scale from thousands to millions of users.",
            "It's time to turn your product into a movement!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Start Level 5: Go-to-Market",
              "action": "start_simulator"
            },
            {
              "text": "How do I scale growth?",
              "action": "dialogue",
              "nextDialogue": "growth_help"
            },
            {
              "text": "I'll come back later",
              "action": "close"
            }
          ]
        },
        "growth_help": {
          "id": "growth_help",
          "trigger": "interaction",
          "lines": [
            "Growth is a science, not magic. Test channels systematically.",
            "Know your unit economics: CAC, LTV, payback period, retention cohorts.",
            "The best growth channel is the one your competitors aren't using.",
            "Viral loops compound - a 1.1x viral coefficient beats 10% weekly growth.",
            "Product-led growth works when your product sells itself.",
            "Scale what works, kill what doesn't. Fast!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Let's grow this thing!",
              "action": "start_simulator"
            },
            {
              "text": "Back to main menu",
              "action": "dialogue",
              "nextDialogue": "greeting"
            }
          ]
        }
      }
    },
