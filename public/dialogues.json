    "garage_npc": {
      "id": "garage_npc",
      "name": "Alex the Builder",
      "color": "#2C3E50",
      "location": "garage",
      "position": { "x": -4, "y": 0.1, "z": -2 },
      "spritePath": "/assets/textures/npc/alex-builder.png",
      "dialogues": {
        "greeting": {
          "id": "greeting",
          "trigger": "proximity",
          "lines": [
            "Hey! Welcome to my garage - where ideas become reality.",
            "This is Level 2: MVP Development.",
            "Goal: Ship a minimum viable product in 3 sprints.",
            "Time to turn your validated idea into working software!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Start Level 2: MVP Development",
              "action": "start_simulator"
            },
            {
              "text": "Tell me about building an MVP",
              "action": "dialogue",
              "nextDialogue": "mvp_help"
            },
            {
              "text": "I'll come back later",
              "action": "close"
            }
          ]
        },
        "mvp_help": {
          "id": "mvp_help",
          "trigger": "interaction",
          "lines": [
            "MVP means Minimum Viable Product - the simplest version that solves the core problem.",
            "Don't build features nobody asked for. Focus on the essential value proposition.",
            "Ship fast, gather feedback, iterate. Perfect is the enemy of done.",
            "Pick the right tech stack - familiar beats trendy when you're moving fast.",
            "Technical debt is okay early on, but document it so you know where it is.",
            "Your first users will forgive bugs if the core value is there!"
          ],
          "repeatable": true,
          "choices": [
            {
              "text": "Let's build this thing!",
              "action": "start_simulator"
            },
            {
              "text": "Back to main menu",
              "action": "dialogue",
              "nextDialogue": "greeting"
            }
          ]
        }
      }
    },
